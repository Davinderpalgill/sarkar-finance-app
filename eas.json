{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": false
      }
    },
    "production": {
      "distribution": "internal",
      "ios": {
